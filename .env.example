# ── AI ─────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...           # GPT-4o: story extraction + tweet writing
ANTHROPIC_API_KEY=sk-ant-...   # Claude Sonnet: LinkedIn post writing

# ── Email ingestion (AgentMail) ────────────────────────────────────────────────
AGENTMAIL_API_KEY=...
SENDER_INBOX_ID=your-inbox@agentmail.to   # The inbox Alabama reads newsletters from

# ── Email sending (SMTP) ───────────────────────────────────────────────────────
SENDER_EMAIL=you@yourdomain.com           # The address Alabama sends the briefing from
SENDER_APP_PASSWORD=...                   # App password for the SMTP account
SENDER_SMTP_SERVER=smtp.zoho.com          # Default: Zoho — change to smtp.gmail.com etc.
SENDER_SMTP_PORT=465

RECIPIENT_EMAIL=you@example.com           # Comma-separated for multiple recipients

# ── Buffer (social publishing) ─────────────────────────────────────────────────
BUFFER_ACCESS_TOKEN=...
BUFFER_CHANNEL_ID=...          # Twitter/X channel ID
LINKEDIN_CHANNEL_ID=...        # LinkedIn channel ID
TWITTER_CHANNEL_ID=            # Optional: separate Twitter channel (leave blank if same as above)

# ── Context (optional override) ───────────────────────────────────────────────
# CONTEXT_DIR=/absolute/path/to/your/context   # Default: ./context inside this repo

# ── Story categories (optional — defaults shown) ──────────────────────────────
# Pipe-separated key:label pairs. Order matters: the LAST category is treated as
# the rarest and wins LinkedIn tie-breaks. Keys must be single characters (numbers
# for parent categories, letters for sub-categories).
#
# STORY_CATEGORIES=1:AI & Machine Learning|2:Blockchain & Crypto|3:Fintech & Insurtech|4:Consulting & Professional Services
# STORY_SUBCATEGORIES=A:New Products & Launches|B:Funding M&A & Partnerships|C:Use Cases & Deployments|D:Business/Tech Impact & Trends
