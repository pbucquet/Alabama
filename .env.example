# ════════════════════════════════════════════════════════════════════════════════
# REQUIRED
# ════════════════════════════════════════════════════════════════════════════════

# ── AI ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...           # GPT-4o: story extraction, tweet writing, LinkedIn fallback

# ── Email sending (SMTP) ────────────────────────────────────────────────────────
SENDER_EMAIL=you@yourdomain.com           # The address Alabama sends the briefing from
SENDER_APP_PASSWORD=...                   # App password for the SMTP account
SENDER_SMTP_SERVER=smtp.zoho.com          # Default: Zoho — change to smtp.gmail.com etc.
SENDER_SMTP_PORT=465

RECIPIENT_EMAIL=you@example.com           # Comma-separated for multiple recipients
EMAIL_SUBJECT_PREFIX=Daily Newsletter Briefing   # Subject line prefix — date is appended automatically

# ════════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Alabama runs without these; the relevant step is skipped if absent
# ════════════════════════════════════════════════════════════════════════════════

# ── Newsletter email ingestion (AgentMail) ──────────────────────────────────────
# Leave blank to skip fetching newsletters from an inbox.
# You can still use web sources (sources.md) without this.
AGENTMAIL_API_KEY=
SENDER_INBOX_ID=                          # e.g. your-inbox@agentmail.to

# ── Buffer — tweets ─────────────────────────────────────────────────────────────
# Leave BUFFER_CHANNEL_ID blank to skip tweet publishing entirely.
BUFFER_ACCESS_TOKEN=
BUFFER_CHANNEL_ID=                        # Twitter/X channel ID in Buffer

# ── Buffer — LinkedIn ───────────────────────────────────────────────────────────
# Leave LINKEDIN_CHANNEL_ID blank to skip LinkedIn publishing entirely.
LINKEDIN_CHANNEL_ID=                      # LinkedIn channel ID in Buffer
TWITTER_CHANNEL_ID=                       # Optional second Twitter channel for LinkedIn companion tweet
INSTAGRAM_CHANNEL_ID=                     # Instagram channel ID in Buffer (for image posts)

# ── Cloudinary (image hosting for Instagram) ────────────────────────────────────
# Required for Instagram image generation. Free tier is sufficient.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Anthropic (optional) ────────────────────────────────────────────────────────
# If set, Claude Sonnet is used to write LinkedIn posts.
# If absent, GPT-4o is used instead (requires OPENAI_API_KEY above).
ANTHROPIC_API_KEY=

# ── Context directory ───────────────────────────────────────────────────────────
# Default: ./context inside this repo. Override if you store context files elsewhere.
# CONTEXT_DIR=/absolute/path/to/your/context

# ── Story categories ────────────────────────────────────────────────────────────
# Pipe-separated key:label pairs. Order matters: the LAST category is treated as
# the rarest and wins LinkedIn tie-breaks. Keys must be single characters.
# Defaults are shown — uncomment and edit to customise.
# STORY_CATEGORIES=1:AI & Machine Learning|2:Blockchain & Crypto|3:Fintech & Insurtech|4:Consulting & Professional Services
# STORY_SUBCATEGORIES=A:New Products & Launches|B:Funding M&A & Partnerships|C:Use Cases & Deployments|D:Business/Tech Impact & Trends

# ── Grading criteria ─────────────────────────────────────────────────────────
# Defines what GPT-4o optimises for when assigning grades 1-10.
# Default targets a business/market intelligence audience.
# GRADE_CRITERIA=business impact + novelty
